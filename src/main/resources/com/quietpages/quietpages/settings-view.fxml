<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.quietpages.quietpages.controller.SettingsController"
            fitToWidth="true"
            styleClass="library-root book-scroll-pane">
    <content>
        <VBox spacing="32" styleClass="library-root">
            <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

            <!-- Appearance -->
            <VBox spacing="12">
                <Label text="Appearance"
                       style="-fx-text-fill:-qp-text-primary;-fx-font-size:18px;-fx-font-weight:bold;"/>
                <Label text="Choose a theme for the entire application."
                       style="-fx-text-fill:-qp-text-secondary;-fx-font-size:13px;"/>

                <!-- Same 8 themes as teammate's SettingsPage.java -->
                <FlowPane fx:id="themesPane" hgap="12" vgap="12">
                    <Button fx:id="btnLight"    text="Light"    onAction="#onLight"    styleClass="settings-theme-btn"/>
                    <Button fx:id="btnDark"     text="Dark"     onAction="#onDark"     styleClass="settings-theme-btn"/>
                    <Button fx:id="btnOcean"    text="Ocean"    onAction="#onOcean"    styleClass="settings-theme-btn"/>
                    <Button fx:id="btnSunset"   text="Sunset"   onAction="#onSunset"   styleClass="settings-theme-btn"/>
                    <Button fx:id="btnForest"   text="Forest"   onAction="#onForest"   styleClass="settings-theme-btn"/>
                    <Button fx:id="btnLavender" text="Lavender" onAction="#onLavender" styleClass="settings-theme-btn"/>
                    <Button fx:id="btnRose"     text="Rose"     onAction="#onRose"     styleClass="settings-theme-btn"/>
                    <Button fx:id="btnMidnight" text="Midnight" onAction="#onMidnight" styleClass="settings-theme-btn"/>
                </FlowPane>
            </VBox>

            <Separator style="-fx-background-color:-qp-border;"/>

            <!-- About -->
            <VBox spacing="8">
                <Label text="About"
                       style="-fx-text-fill:-qp-text-primary;-fx-font-size:18px;-fx-font-weight:bold;"/>
                <Label text="QuietPages — EPUB Reader"
                       style="-fx-text-fill:-qp-text-secondary;-fx-font-size:13px;"/>
                <Label text="Version 1.0-SNAPSHOT"
                       style="-fx-text-fill:-qp-text-secondary;-fx-font-size:13px;"/>
            </VBox>

        </VBox>
    </content>
</ScrollPane>
